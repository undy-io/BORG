{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,

  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },

    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag":        { "type": "string" },
        "pullPolicy": { "type": "string" }
      },
      "required": ["repository"]
    },

    "authKeySecret": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "key":  { "type": "string" },
        "value": {
          "type": "string",
          "description": "Optional printable auth key string to store in the secret"
        }
      },
      "required": ["name", "key"]
    },

    "apikeySecrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },

    "config": {
      "type": "object",
      "description": "Proxy runtime configuration",
      "additionalProperties": true
    },

    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "secretName": { "type": "string" },
            "mountPath": { "type": "string" },
            "certKey": { "type": "string" },
            "privateKeyKey": { "type": "string" }
          },
          "required": ["enabled", "mountPath", "certKey", "privateKeyKey"]
        }
      },
      "required": ["tls"]
    },

    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "loadBalancerClass": { "type": "string" },
        "loadBalancerIP": { "type": "string" },
        "loadBalancerSourceRanges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "externalTrafficPolicy": {
          "type": "string",
          "enum": ["Cluster", "Local"]
        },
        "port":       { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["port"]
    },

    "ingress": {
      "type": "object",
      "additionalProperties": false,

      "properties": {
        "enabled":   { "type": "boolean" },
        "className": { "type": "string" },

        "annotations": {
          "type": "object",
          "description": "Extra annotations on the Ingress",
          "additionalProperties": { "type": "string" }
        },

        "issuer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name":  { "type": "string" },
            "kind":  { "type": "string", "enum": ["Issuer", "ClusterIssuer"] },
            "scope": { "type": "string", "enum": ["namespaced", "cluster"] },

            "annotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },

            "cert": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },

                "subject": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "commonName":          { "type": "string", "optional": true },
                    "organizations":       { "type": "array", "items": { "type": "string" } },
                    "organizationalUnits": { "type": "array", "items": { "type": "string" } },
                    "countries":           { "type": "array", "items": { "type": "string", "minLength": 2, "maxLength": 2 } },
                    "localities":          { "type": "array", "items": { "type": "string" } },
                    "provinces":           { "type": "array", "items": { "type": "string" } }
                  }
                },

                "altNames": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "required": ["name"]
        },

        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host":  { "type": "string", "pattern": "^[A-Za-z0-9.-]+$" },

              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path":     { "type": "string" },
                    "pathType": { "type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"] }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["host"]
          }
        },

        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },

            "secretName": {
              "type": "string",
              "description": "Override for the TLS secret (<release>-tls by default)"
            },

            "existingSecret": {
              "type": ["string", "null"],
              "description": "Reference to a pre-created secret"
            }
          }
        }
      },

      "required": ["enabled", "hosts"]
    },

    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "secretName": { "type": "string" },
        "commonName": { "type": "string" },
        "dnsNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "altNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ipAddresses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uris": {
          "type": "array",
          "items": { "type": "string" }
        },
        "emailAddresses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "issuerRef": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string" },
            "group": { "type": "string" }
          }
        },
        "usages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "organizations":       { "type": "array", "items": { "type": "string" } },
            "organizationalUnits": { "type": "array", "items": { "type": "string" } },
            "countries":           { "type": "array", "items": { "type": "string", "minLength": 2, "maxLength": 2 } },
            "localities":          { "type": "array", "items": { "type": "string" } },
            "provinces":           { "type": "array", "items": { "type": "string" } },
            "streetAddresses":     { "type": "array", "items": { "type": "string" } },
            "postalCodes":         { "type": "array", "items": { "type": "string" } },
            "serialNumber":        { "type": "string" }
          }
        }
      }
    }
  }
}
